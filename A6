# ---------------- MAIN SYSTEM ----------------

def expert_system():

    while True:

        print("\n" + "=" * 20 + " MAIN MENU " + "=" * 20)

        print("1. Patient Symptom Analysis")
        print("2. Emergency Services")
        print("3. Hospital Facilities")
        print("4. Specialist Departments")
        print("5. About Expert System")
        print("6. Exit")

        choice = input("\nEnter your choice: ")

        if choice == "1":
            patient_analysis()

        elif choice == "2":
            emergency_services()

        elif choice == "3":
            hospital_facilities()

        elif choice == "4":
            departments()

        elif choice == "5":
            about_system()

        elif choice == "6":
            print("\nThank You for Using Medical Expert System!")
            print("Stay Healthy and Safe.")
            break

        else:
            print("\nInvalid Choice! Please Try Again.")


