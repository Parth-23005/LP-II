# ---------------- INTRODUCTION ----------------

def intro():

    print("=" * 70)
    print("     EXPERT SYSTEM FOR HOSPITALS AND MEDICAL FACILITIES")
    print("=" * 70)


# ---------------- PATIENT ANALYSIS ----------------

def patient_analysis():

    print("\n" + "-" * 15 + " PATIENT DETAILS " + "-" * 15)

    name = input("Enter Patient Name : ")

    age = int(input("Enter Patient Age  : "))

    print("\nAnswer the following questions with yes/no\n")

    fever        = input("Do you have fever?                    : ")
    cough        = input("Do you have cough?                    : ")
    chest_pain   = input("Do you have chest pain?               : ")
    headache     = input("Do you have headache?                 : ")
    stomach      = input("Do you have stomach pain?             : ")
    injury       = input("Do you have any injury/fracture?      : ")
    skin_rash    = input("Do you have skin rash/itching?        : ")
    breathless   = input("Do you have difficulty breathing?     : ")
    high_sugar   = input("Do you have high sugar/frequent urine?: ")
    body_ache    = input("Do you have body ache/joint pain?     : ")

    print("\n" + "-" * 15 + " MEDICAL REPORT " + "-" * 15)

    print("\nPatient Name :", name)
    print("Patient Age  :", age)

    # ---------------- EXPERT RULES (10 DISEASES) ----------------

    # DISEASE 1: Viral Infection / Flu
    if fever == "yes" and cough == "yes":

        print("\nPossible Condition    : Viral Infection or Flu")
        print("\nRecommended Department: General Medicine")
        print("\nDoctor Suggestion     : Consult General Physician")
        print("\nMedical Advice:")
        print("- Drink plenty of water")
        print("- Take proper rest")
        print("- Monitor body temperature")

    # DISEASE 2: Heart Problem
    elif chest_pain == "yes":

        print("\nPossible Condition    : Heart Related Problem")
        print("\nRecommended Department: Cardiology")
        print("\nDoctor Suggestion     : Consult Heart Specialist Immediately")
        print("\nEmergency Advice:")
        print("- Avoid physical activity")
        print("- Visit nearest hospital immediately")

    # DISEASE 3: Migraine / Stress
    elif headache == "yes" and fever == "no":

        print("\nPossible Condition    : Migraine or Stress")
        print("\nRecommended Department: Neurology")
        print("\nDoctor Suggestion     : Consult Neurologist")
        print("\nMedical Advice:")
        print("- Take adequate rest")
        print("- Avoid stress")
        print("- Stay hydrated")

    # DISEASE 4: Digestion Problem
    elif stomach == "yes":

        print("\nPossible Condition    : Digestion Problem or Infection")
        print("\nRecommended Department: Gastroenterology")
        print("\nDoctor Suggestion     : Consult Stomach Specialist")
        print("\nMedical Advice:")
        print("- Eat light food")
        print("- Avoid oily/spicy food")

    # DISEASE 5: Bone Injury / Fracture
    elif injury == "yes":

        print("\nPossible Condition    : Bone Injury or Fracture")
        print("\nRecommended Department: Orthopedics")
        print("\nDoctor Suggestion     : Consult Orthopedic Doctor")
        print("\nEmergency Advice:")
        print("- Avoid moving injured area")
        print("- Apply ice if swelling occurs")

    # DISEASE 6: Skin Infection / Allergy
    elif skin_rash == "yes":

        print("\nPossible Condition    : Skin Infection or Allergy")
        print("\nRecommended Department: Dermatology")
        print("\nDoctor Suggestion     : Consult Dermatologist")
        print("\nMedical Advice:")
        print("- Avoid scratching affected area")
        print("- Apply prescribed cream")
        print("- Avoid allergens")

    # DISEASE 7: Asthma / Respiratory Problem
    elif breathless == "yes" and cough == "yes":

        print("\nPossible Condition    : Asthma or Respiratory Problem")
        print("\nRecommended Department: Pulmonology")
        print("\nDoctor Suggestion     : Consult Pulmonologist")
        print("\nMedical Advice:")
        print("- Use inhaler if prescribed")
        print("- Avoid dusty environments")
        print("- Avoid physical exertion")

    # DISEASE 8: Diabetes
    elif high_sugar == "yes":

        print("\nPossible Condition    : Diabetes Mellitus")
        print("\nRecommended Department: Endocrinology")
        print("\nDoctor Suggestion     : Consult Endocrinologist")
        print("\nMedical Advice:")
        print("- Avoid sugary food and drinks")
        print("- Monitor blood sugar regularly")
        print("- Follow prescribed diet plan")

    # DISEASE 9: Dengue / Typhoid
    elif fever == "yes" and body_ache == "yes":

        print("\nPossible Condition    : Dengue or Typhoid")
        print("\nRecommended Department: Infectious Disease / General Medicine")
        print("\nDoctor Suggestion     : Consult General Physician Immediately")
        print("\nMedical Advice:")
        print("- Get blood test done immediately")
        print("- Drink plenty of fluids")
        print("- Take complete bed rest")

    # DISEASE 10: Arthritis / Joint Pain
    elif body_ache == "yes" and fever == "no":

        print("\nPossible Condition    : Arthritis or Joint Pain")
        print("\nRecommended Department: Rheumatology / Orthopedics")
        print("\nDoctor Suggestion     : Consult Rheumatologist")
        print("\nMedical Advice:")
        print("- Avoid heavy physical work")
        print("- Apply warm compress on joints")
        print("- Take prescribed pain relief medication")

    # NO MAJOR SYMPTOMS
    else:

        print("\nNo Major Symptoms Detected.")
        print("\nGeneral Advice:")
        print("- Maintain healthy lifestyle")
        print("- Regular health checkup recommended")


